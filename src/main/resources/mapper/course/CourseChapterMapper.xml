<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.hlinks.domain.course.mapper.CourseChapterMapper">

    <resultMap id="courseChapterResultMap" type="com.hlinks.domain.course.entity.CourseChapter">
        <id property="chapterId" column="CHAPTER_ID"/>
        <result property="courseId" column="COURSE_ID"/>
        <result property="chapterTitle" column="CHAPTER_TITLE"/>
        <result property="chapterOrder" column="CHAPTER_ORDER"/>
        <result property="videoUrl" column="VIDEO_URL"/>
        <result property="durationSeconds" column="DURATION_SECONDS"/>
        <result property="summaryText" column="SUMMARY_TEXT"/>
        <result property="transcriptText" column="TRANSCRIPT_TEXT"/>
        <result property="aiGeneratedYn" column="AI_GENERATED_YN"/>
        <result property="useYn" column="USE_YN"/>
        <result property="createdAt" column="CREATED_AT"/>
        <result property="updatedAt" column="UPDATED_AT"/>
    </resultMap>

    <select id="findById" resultMap="courseChapterResultMap">
        SELECT
        CHAPTER_ID,
        COURSE_ID,
        CHAPTER_TITLE,
        CHAPTER_ORDER,
        VIDEO_URL,
        DURATION_SECONDS,
        SUMMARY_TEXT,
        TRANSCRIPT_TEXT,
        AI_GENERATED_YN,
        USE_YN,
        CREATED_AT,
        UPDATED_AT
        FROM COURSE_CHAPTER
        WHERE CHAPTER_ID = #{chapterId}
        AND USE_YN = 'Y'
    </select>

    <update id="updateTranscriptText">
        UPDATE COURSE_CHAPTER
        SET
        TRANSCRIPT_TEXT = #{transcriptText},
        AI_GENERATED_YN = 'Y',
        UPDATED_AT = SYSDATE
        WHERE CHAPTER_ID = #{chapterId}
        AND USE_YN = 'Y'
    </update>

</mapper>